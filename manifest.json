{
  "manifest_version": 3,
  "name": "Procrastinate Not (YouTube Intent)",
  "version": "0.1.0",
  "description": "Reduce unconscious YouTube usage through intent-setting and lightweight nudges.",
  "permissions": ["storage", "tabs", "alarms"],
  "host_permissions": ["https://www.youtube.com/*"],
  "background": {
    "service_worker": "background/service_worker.js",
    "type": "module"
  },
  "action": {
    "default_title": "YouTube Intent",
    "default_popup": "ui/analytics.html"
  },
  "options_page": "ui/app.html",
  "content_scripts": [
    {
      "matches": ["https://www.youtube.com/*"],
      "js": [
        "content/constants.js",
        "content/storage.js",
        "content/spa.js",
        "content/ui_modal.js",
        "content/session.js",
        "content/friction.js",
        "content/notes.js",
        "content/main.js"
      ],
      "css": ["ui/modal.css"],
      "run_at": "document_start"
    }
  ]
}

